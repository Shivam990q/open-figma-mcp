# Normalize line endings: store as LF in the repo, check out native on Windows.
* text=auto eol=lf

# Explicit text types
*.js   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Binary assets (never normalize)
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.pdf  binary
