# Copy to .env and fill in. NEVER commit your real .env.
# Generate a token at: Figma → Settings → Security → Personal access tokens
# Scopes needed: "File content: Read" and "Dev resources: Read".

FIGMA_API_KEY=figd_your_personal_access_token_here

# --- Optional ---
# OAuth Bearer token (takes precedence over FIGMA_API_KEY if both are set)
# FIGMA_OAUTH_TOKEN=

# HTTP server (3845 = Lovable autodetect; set 3333 for figma-developer-mcp parity)
# FRAMELINK_PORT=3845
# FRAMELINK_HOST=127.0.0.1

# Output format: yaml | json | tree
# OUTPUT_FORMAT=yaml

# Where downloaded images go (autodetected if unset: public/, src/assets, ...)
# IMAGE_DIR=

# Corporate proxy (or "none" to bypass inherited proxy env vars)
# FIGMA_PROXY=
